{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**", "/icons/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-menu",
      "urls": ["/api/menu", "/api/settings"],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "1h",
        "strategy": "freshness"
      }
    }
  ]
}
