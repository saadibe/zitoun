<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="6-create-refresh-token" author="zitoun">
        <createTable tableName="refresh_token">
            <column name="id" type="BIGSERIAL"><constraints primaryKey="true" nullable="false"/></column>
            <column name="token" type="VARCHAR(512)"><constraints nullable="false" unique="true"/></column>
            <column name="user_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_refresh_user" references="app_user(id)"/></column>
            <column name="expires_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="revoked" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
        <createIndex tableName="refresh_token" indexName="idx_refresh_token">
            <column name="token"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
