<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="12-index-orders-status" author="system">
        <createIndex indexName="idx_orders_status" tableName="orders">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_orders_table_status" tableName="orders">
            <column name="table_number"/>
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_orders_created_at" tableName="orders">
            <column name="created_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
